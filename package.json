{
  "name": "financeiq",
  "version": "1.0.0",
  "description": "FinanceIQ - Personal Finance App",
  "main": "server/index.js",
  "scripts": {
    "build": "npm install --prefix client && npm run build --prefix client && node -e \"const fs=require('fs'); const p='client/dist'; console.log('Build output:', fs.existsSync(p)?'exists':'missing')\"",
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npm run dev\"",
    "seed": "node server/db/seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "@google/generative-ai": "^0.21.0",
    "concurrently": "^8.2.2",
    "vite": "^5.4.21",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38"
  }
}
